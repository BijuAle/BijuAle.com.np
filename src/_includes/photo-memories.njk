---
layout: base.njk
title: Photo Memories
---

<section class="photo-grid-wrap">
  <div class="photo-grid">
    {% for tag in photos.tags %}
      {% if photos.byTag[tag] and photos.byTag[tag][0] %}
        <a class="photo-cell" href="/photo-tag/{{ tag | url }}">
          <img
            src="{{ photos.byTag[tag][0].secure_url }}?w=600&h=600&c=fill&f=auto&q=auto"
            alt="{{ tag }}"
            loading="lazy"
          />
          <span class="photo-label">{{ tag | titleCase }}</span>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>

<style>
  /* ── Reset base.njk main text-align so images aren't affected ── */
  main { text-align: left; }

  /* ── Pull grid edge-to-edge, ignoring body padding ── */
  .photo-grid-wrap {
    margin: 1rem -1.5rem 0;
  }

  /* ── 3-column Instagram grid ── */
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3px;
  }

  /* ── Each cell: perfect square, overflow hidden ── */
  .photo-cell {
    position: relative;
    display: block;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #111;
    cursor: pointer;
  }

  /* ── Image fills the square fully ── */
  .photo-cell img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    margin: 0;
    filter: grayscale(25%);
    transition: transform 0.35s ease, filter 0.35s ease;
  }

  /* ── Caption: hidden below the cell, slides up on hover ── */
  .photo-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.65rem 0.5rem 0.5rem;
    font-family: "Linux Biolinium O", sans-serif;
    font-size: clamp(0.65rem, 1.5vw, 0.85rem);
    color: #fff;
    letter-spacing: 0.03em;
    background: linear-gradient(transparent, rgba(0,0,0,0.62));
    transform: translateY(100%);
    transition: transform 0.28s ease;
    text-align: center;
    line-height: 1.3;
    pointer-events: none;
  }

  /* ── Hover: zoom image, desaturate less, slide label up ── */
  .photo-cell:hover img {
    transform: scale(1.06);
    filter: grayscale(0%);
  }

  .photo-cell:hover .photo-label {
    transform: translateY(0);
  }

  /* ── Mobile: tighter, still 3-col ── */
  @media (max-width: 500px) {
    .photo-grid-wrap { margin: 0.75rem -1rem 0; }
    .photo-grid { gap: 2px; }
  }
</style>
