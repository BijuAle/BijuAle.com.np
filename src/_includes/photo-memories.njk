---
layout: base.njk
title: Photo Memories
---

<section class="photo-grid-wrap">
  <div class="photo-grid">
    {% for tag in photos.tags %}
      {% if photos.thumbnails[tag] %}
        <a class="photo-cell" href="/photo-tag/{{ tag | url }}">
          <img
            src="{{ photos.thumbnails[tag].secure_url }}?w=600&h=600&c=fill&f=auto&q=auto"
            alt="{{ tag }}"
            loading="lazy"
          />
          <span class="photo-label">{{ tag | titleCase }}</span>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>


<style>
  /* ── Reset base.njk main text-align ── */
  main { text-align: left; }

  .photo-grid-wrap {
    margin: 2rem 0;
    padding: 0 1rem;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .photo-cell {
    position: relative;
    display: block;
    background: #dcd9d0; /* Soothing Polaroid tone */
    padding: 6px 10px 18px 10px; /* Thinned top border version user liked */
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
    text-decoration: none;
  }

  /* Varied "Hand-Placed" Rotations applied to the cell */
  .photo-cell:nth-child(4n+1) { transform: rotate(-1.5deg); }
  .photo-cell:nth-child(4n+2) { transform: rotate(1.2deg); }
  .photo-cell:nth-child(4n+3) { transform: rotate(-0.8deg); }
  .photo-cell:nth-child(4n+4) { transform: rotate(1.8deg); }

  .photo-cell img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    filter: sepia(5%) contrast(98%);
    margin: 0 !important; /* Overrides global image margin */
    border: none !important;
    transition: filter 0.4s ease;
  }

  .photo-label {
    display: block;
    margin-top: 8px;
    font-family: "Garamond", serif;
    font-size: 0.9rem;
    color: #000;
    text-align: center;
    font-variant: small-caps;
    letter-spacing: 0.05em;
  }

  .photo-cell:hover {
    transform: scale(1.05) rotate(0deg) !important;
    box-shadow: 0 15px 35px rgba(0,0,0,0.2);
    z-index: 100;
  }

  .photo-cell:hover img {
    filter: sepia(0%) contrast(100%);
  }

  @media (max-width: 600px) {
    .photo-grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 1.5rem;
    }
    .photo-cell {
      padding: 6px 6px 20px 6px;
    }
  }
</style>
