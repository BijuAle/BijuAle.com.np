{%- macro cmd(code) -%}
<div class="cmd-block"><code class="cmd-code">{{ code | escape }}</code><button class="cmd-copy" onclick="copyCmd(this)">Copy</button></div>
{%- endmacro -%}

{#
  script(lang, name)
  Blank lines in caller() content are collapsed to single newlines so that
  Markdown-it's HTML block parser never encounters a blank line inside the
  <div> and exits prematurely.
#}
{%- macro script(lang, name) -%}
<div class="script-block"><div class="script-meta"><span class="script-lang">{{ lang }}</span><span class="script-name">{{ name }}</span><div class="script-actions"><button onclick="toggleScript(this)">View</button><button onclick="copyScript(this)">Copy</button><button onclick="downloadScript(this)">Download</button></div></div><pre class="script-content" hidden><code>{{ caller() | trim | replace("\n\n\n", "\n") | replace("\n\n", "\n") | escape }}</code></pre></div>
{%- endmacro -%}
